#pragma once

#include "ti_msp_dl_config.h"
#include "group.h"


{% macro hexify(bytes) -%}
{% if bytes is not none -%}
{% for i in range(0, bytes | length, 2) %}0x{{ bytes[i:i+2] }}, {% endfor %}
{%- endif %}
{%- endmacro %}

#define STAGE1_PIN_ITERATIONS {{ STAGE1_PIN_ITERATIONS }}
#define STAGE1_KEY { {{ hexify(STAGE1_KEY) }} }
#define STAGE1_PADDING { {{ hexify(STAGE1_PADDING) }} }
#define STAGE2_RAND_INT {{ STAGE2_RAND_INT }}
#define STAGE1_PIN_HASH { {{ hexify(STAGE1_PIN_HASH) }} }


const group_t groups[{{ groups | length }}] = {
    {% for group_id, keys in groups | items %}
    {
        .group_id = {{ group_id }},
        .private = {
            .permissions = {
                .read = {{ keys["read"]["private"] is not none }},
                .write = {{ keys["write"]["private"] is not none }},
                .transfer = {{ keys["transfer"]["private"] is not none }},
            }
            .read_key = { {{ hexify(keys["read"]["private"]) }} },
            .write_key = { {{ hexify(keys["write"]["private"]) }} },
            .transfer_key = { {{ hexify(keys["transfer"]["private"]) }} },
        },
        .public = {
            .read_key = { {{ hexify(keys["read"]["public"]) }} },
            .write_key = { {{ hexify(keys["write"]["public"]) }} },
            .transfer_key = { {{ hexify(keys["transfer"]["public"]) }} },
        }
    },
    {% endfor %}
};

