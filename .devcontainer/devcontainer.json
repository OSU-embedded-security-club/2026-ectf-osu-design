{
    "build": {
        "dockerfile": "./Dockerfile"
    },

    "runArgs": [
        "--network=host"
    ],

    "privileged": true,

    "mounts": [
        { "source": "/dev", "target": "/dev:ro", "type": "bind" }
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd"
            ]
        }
    }
}